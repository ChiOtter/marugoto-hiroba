rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasSchoolEmail() {
      return isSignedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@kamiyama\\.ac\\.jp$');
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if hasSchoolEmail();
      allow create: if hasSchoolEmail()
        && isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow update: if hasSchoolEmail()
        && isOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    match /presence/{uid} {
      allow read: if hasSchoolEmail();
      allow create, update: if hasSchoolEmail()
        && isOwner(uid)
        && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }

    match /likes/{likeId} {
      allow read: if hasSchoolEmail()
        && (
          resource.data.fromUid == request.auth.uid
          || resource.data.toUid == request.auth.uid
        );
      allow create: if hasSchoolEmail()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.date is string;
      allow update, delete: if false;
    }

    match /dailyStats/{date}/users/{uid} {
      allow read: if hasSchoolEmail() && isOwner(uid);
      allow create, update: if hasSchoolEmail()
        && isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.date == date;
      allow delete: if false;
    }
  }
}
